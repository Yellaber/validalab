# ─────────────────────────────────────────────────────────────────────────────
# ValidaLab — backend · plantilla de variables de entorno
#
# Copia este archivo a `.env` y rellena los valores. El backend VALIDA estas
# variables al arrancar (fail-fast): si falta una obligatoria o es inválida, el
# proceso aborta el arranque. No subas tu `.env` real al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# --- Aplicación ---
# Entorno de ejecución. Valores: development | test | production
NODE_ENV=development
# Puerto HTTP del servidor. Opcional (por defecto 3000).
PORT=3000

# --- PostgreSQL (TypeORM) ---
# Conexión a la base de datos. Todas obligatorias.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=validalab
DB_PASSWORD=cambia-esto
DB_DATABASE=validalab
# Sincronización automática de esquema. DEBE quedar en false salvo en un arranque
# local desechable. El esquema real se gobierna con migraciones de TypeORM.
DB_SYNCHRONIZE=false

# --- JWT (verificación del accessToken) ---
# Secreto para verificar la firma del accessToken. Obligatorio. Usa un valor
# largo y aleatorio (p. ej. `openssl rand -hex 32`). La EMISIÓN de tokens vive en
# el módulo `usuarios`; esta fundación solo VERIFICA.
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Tiempo de vida del accessToken (formato de `ms`/jsonwebtoken, p. ej. 15m, 1h).
JWT_ACCESS_TTL=15m
